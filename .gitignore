# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Environment / secrets
.env
.env.*
*.secret
*.key

# Logs
*.log
logs/
log/

# Jupyter
.ipynb_checkpoints/

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Test / coverage artifacts
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Build artifacts
build/
dist/
*.egg-info/

# Local outputs
data/
output/
outputs/
tmp/
temp/

# Browser automation artifacts
playwright-report/
test-results/

# Large generated data
*.csv
*.tsv
*.jsonl
*.parquet
*.pkl
*.joblib

# Optional: exclude generated model files
models/**/*.pkl
models/**/*.joblib
models/**/*.bin

# Optional: exclude raw saved html if they are generated artifacts
html/**/*.html

# Keep placeholders or samples if needed
!data/.gitkeep
!data/sample/
!data/sample/**
!features/.gitkeep
!models/.gitkeep
!html/.gitkeep